# SQLite-backed persistence (default if unset: data/operatoros.db)
OPERATOROS_DATABASE_PATH=./data/operatoros.db

# Owner login password for app-native auth
OWNER_PASSWORD=change-me-before-production

# Optional legacy JSON path. If present and a matching sqlite DB does not exist yet,
# OperatorOS will import the JSON snapshot into a sibling .sqlite file once.
# OPERATOROS_DATA_PATH=./data/operatoros-db.json
