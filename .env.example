# SQLite-backed persistence
OPERATOROS_DATABASE_PATH=./data/operatoros.db

# Public base URL used when creating checkout URLs
OPERATOROS_BASE_URL=https://operatoros.example.com

# Operator accounts (owner / operator / reviewer)
# Example:
# OPERATOROS_USERS_JSON=[{"username":"operatoros","password":"change-me","role":"owner"},{"username":"ops","password":"change-me-too","role":"operator"},{"username":"reviewer","password":"review-me","role":"reviewer"}]

# Legacy single-owner fallback (kept for backward compatibility)
# OWNER_PASSWORD=change-me

# Real payment provider. When this is unset, live checkout is disabled by default.
# STRIPE_SECRET_KEY=sk_test_or_live_here
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional explicit sandbox mode for non-production demos/tests only.
# OPERATOROS_ALLOW_SANDBOX_PAYMENTS=1

# Optional legacy JSON path. If present and a matching sqlite DB does not exist yet,
# OperatorOS will import the JSON snapshot into a sibling .sqlite file once.
# OPERATOROS_DATA_PATH=./data/operatoros-db.json
